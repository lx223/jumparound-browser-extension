{
  "name": "jumparound",
  "version": "0.1.1",
  "description": "Cross-browser tab switcher with keyboard shortcuts",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc && vite build",
    "build:chrome": "npm run build",
    "build:safari": "npm run build && npm run convert:safari",
    "convert:safari": "xcrun safari-web-extension-converter dist --app-name JumpAround --bundle-identifier jumparound.lanxiao.dev",
    "generate-icons": "node scripts/generate-icons.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/chrome": "^0.1.36",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.8.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^7.3.2",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  }
}
